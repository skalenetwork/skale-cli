{
  "name": "@skalenetwork/cli",
  "version": "0.1.1",
  "type": "module",
  "private": false,
  "description": "SKALE Network CLI Tool for developers and chain owners",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile dist/skale --target bun",
    "start": "./dist/skale"
  },
  "bin": {
    "skale": "dist/skale"
  },
  "keywords": [
    "skale",
    "web3",
    "blockchain",
    "cli",
    "dev",
    "chain"
  ],
  "author": "Sawyer Cutler <sawyer@dirtroad.dev>",
  "license": "MIT",
  "dependencies": {
    "@skalenetwork/bite": "^0.7.2",
    "incur": "^0.1.12",
    "viem": "^2.22.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.2.5",
    "typescript": "^5.9.3"
  }
}
