{
  "name": "@skalenetwork/cli",
  "version": "0.1.7",
  "type": "module",
  "private": false,
  "description": "SKALE Network CLI Tool for developers, chain operators, and agents",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile dist/skale --target bun",
    "start": "./dist/skale"
  },
  "bin": {
    "skale": "dist/skale"
  },
  "keywords": [
    "skale",
    "skale-network",
    "web3",
    "blockchain",
    "ethereum",
    "layer2",
    "cli",
    "cli-tool",
    "dev",
    "chain",
    "ai",
    "agents",
    "mcp",
    "automation",
    "ai-agents"
  ],
  "author": "Sawyer Cutler <sawyer@dirtroad.dev>",
  "license": "MIT",
  "files": [
    "dist/"
  ],
  "dependencies": {
    "@skalenetwork/bite": "^0.7.2",
    "incur": "^0.1.12",
    "viem": "^2.22.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.2.5",
    "typescript": "^5.9.3"
  }
}
